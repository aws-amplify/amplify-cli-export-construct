# Roko Configuration
# Generated by 'roko init'

# ============================================================================
# Database Configuration
# ============================================================================
# PostgreSQL connection string (auto-managed by 'roko start')
DATABASE_URL=postgres://roko:roko@localhost:5432/roko

# ============================================================================
# Server Configuration
# ============================================================================
ROKO_PORT=3001
ROKO_HOST=127.0.0.1

# ============================================================================
# AI/LLM Configuration
# ============================================================================
# AWS profile to use for Bedrock (defaults to 'roko')
# The CLI automatically sets AWS_PROFILE=roko if not already set.
# Override below only if you use a different profile name.
# AWS_PROFILE=roko

# Default model (Claude Sonnet 4.5)
# DEFAULT_MODEL=anthropic.claude-sonnet-4-5-20250929-v1:0

# ============================================================================
# Project Settings
# ============================================================================
PROJECT_NAME=amplify-cli-export-construct

# ============================================================================
# Development Settings
# ============================================================================
# Log level: debug, info, warn, error
LOG_LEVEL=info

# Enable hot reload for agents
HOT_RELOAD_ENABLED=true
